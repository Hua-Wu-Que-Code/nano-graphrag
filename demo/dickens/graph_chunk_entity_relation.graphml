      <data key="d4">8.0</data>
      <data key="d5">"朱重八 is also sent to河南 to beg for food, further shaping his character and worldview."</data>
      <data key="d6">chunk-b26706fdda696524be1e5ff48c2836c2</data>
      <data key="d7">1</data>
    </edge>
