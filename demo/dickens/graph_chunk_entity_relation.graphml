      <data key="d4">8.0</data>
      <data key="d5">"朱元璋多次击败元军，展现军事才能并奠定霸业基础。"</data>
      <data key="d6">chunk-41fce71cb1f6198f0eb409c3481892ec</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱元璋&quot;" target="&quot;明王朝&quot;">
      <data key="d4">10.0</data>
      <data key="d5">"朱元璋是明王朝的建立者，其早期团队构成王朝核心。"</data>
      <data key="d6">chunk-41fce71cb1f6198f0eb409c3481892ec</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱元璋&quot;" target="&quot;黄巢&quot;">
      <data key="d4">7.0</data>
      <data key="d5">"朱元璋与黄巢都是起义领袖，文本通过黄巢的事迹衬托朱元璋的崛起。"</data>
      <data key="d6">chunk-41fce71cb1f6198f0eb409c3481892ec</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱元璋&quot;" target="&quot;占卜&quot;">
      <data key="d4">6.0</data>
      <data key="d5">"占卜反映了朱元璋早年的迷茫，与其后来的果断形成对比。"</data>
      <data key="d6">chunk-41fce71cb1f6198f0eb409c3481892ec</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱五四&quot;" target="&quot;元王朝&quot;">
      <data key="d4">8.0</data>
      <data key="d5">"朱五四作为贫农，深受元王朝腐败统治的压迫，他的生活反映了元朝末年农民的普遍困境。"</data>
      <data key="d6">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;刘德&quot;" target="&quot;元王朝&quot;">
      <data key="d4">7.0</data>
      <data key="d5">"刘德作为地主，是元王朝统治下剥削阶级的代表，他的存在反映了元朝社会的阶级矛盾。"</data>
      <data key="d6">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;刘德&quot;" target="&quot;放牛时期&quot;">
      <data key="d4">8.0</data>
      <data key="d5">"放牛时期直接关联地主刘德，十二年的剥削经历埋下朱元璋阶级仇恨。"</data>
      <data key="d6">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;刘德&quot;" target="&quot;朱重八&quot;">
      <data key="d4">15.0</data>
      <data key="d5">"刘德's refusal to help朱重八 bury his parents exemplifies the social injustices朱重八 faces under the Yuan Dynasty."&lt;SEP&gt;"朱重八 is denied help by 刘德 when trying to bury his parents, showing the landlord's indifference."</data>
      <data key="d6">chunk-b26706fdda696524be1e5ff48c2836c2&lt;SEP&gt;chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;元王朝&quot;" target="&quot;元史&quot;">
      <data key="d4">9.0</data>
      <data key="d5">"《元史》记载蒙古统治者暴政，成为朱元璋起义的合法性来源之一。"</data>
      <data key="d6">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;元王朝&quot;" target="&quot;做和尚时期&quot;">
      <data key="d4">7.0</data>
      <data key="d5">"僧人被迫讨饭反映元末宗教体系崩溃，社会矛盾已达临界点。"</data>
      <data key="d6">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;元王朝&quot;" target="&quot;造反时期&quot;">
      <data key="d4">10.0</data>
      <data key="d5">"1352-1368年造反直接导致元朝灭亡，完成历史更替。"</data>
      <data key="d6">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;中国&quot;" target="&quot;元代&quot;">
      <data key="d4">8.0</data>
      <data key="d5">"The Yuan Dynasty governed China during this historical period of decline and natural disasters."</data>
      <data key="d6">chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;1344年&quot;" target="&quot;黄河&quot;">
      <data key="d4">9.0</data>
      <data key="d5">"黄河灾变是1344年重大事件，直接引发"石人一只眼"起义预言。"</data>
      <data key="d6">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;朱百六&quot;">
      <data key="d4">7.0</data>
      <data key="d5">"朱百六是朱重八的高祖父，数字命名体现家族世代贫农身份。"</data>
      <data key="d6">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;朱四九&quot;">
      <data key="d4">7.0</data>
      <data key="d5">"朱四九是朱重八的曾祖父，连续数字名显示朱家数代受元朝命名限制。"</data>
      <data key="d6">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;朱初一&quot;">
      <data key="d4">7.0</data>
      <data key="d5">"朱初一是朱重八的祖父，命名方式强化朱家底层民众的身份特征。"</data>
      <data key="d6">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;吴老太&quot;">
      <data key="d4">6.0</data>
      <data key="d5">"朱重八曾幻想通过吴老太说媒成家，反映其早期安于现状的平民心态。"</data>
      <data key="d6">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;刘小德&quot;">
      <data key="d4">5.0</data>
      <data key="d5">"虚构人物，体现朱重八对阶级代际传递的认知，子女注定重复其放牛命运。"</data>
      <data key="d6">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;破茅草屋&quot;">
      <data key="d4">8.0</data>
      <data key="d5">"破茅草屋是朱重八童年物质匮乏的具象化体现，塑造其坚韧性格。"</data>
      <data key="d6">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;元&quot;">
      <data key="d4">8.0</data>
      <data key="d5">"朱重八's suffering under the Yuan Dynasty's rule and his later role in its overthrow highlight his opposition to the regime."</data>
      <data key="d6">chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;朱重八的父亲&quot;">
      <data key="d4">9.0</data>
      <data key="d5">"朱重八 witnessed his father's death from starvation during the famine."</data>
      <data key="d6">chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;地主家&quot;">
      <data key="d4">8.0</data>
      <data key="d5">"The landlord class represented by刘德 refused to help朱重八 bury his parents."</data>
      <data key="d6">chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;皇觉寺&quot;">
      <data key="d4">14.0</data>
      <data key="d5">"朱重八 becomes a monk at 皇觉寺 but is treated poorly and forced to do menial tasks."&lt;SEP&gt;"朱重八曾在皇觉寺生活和修行，这里是他人生转变的重要地点。"</data>
      <data key="d6">chunk-9a76d8ffa3427c606f749054f4201706&lt;SEP&gt;chunk-b26706fdda696524be1e5ff48c2836c2</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;淮西&quot;">
      <data key="d4">12.0</data>
      <data key="d5">"朱重八 is sent to 淮西 to beg for food, where he gains valuable experience and connections."&lt;SEP&gt;"朱重八在淮西讨饭三年，经历了人生的重大转变，磨练了意志。"</data>
      <data key="d6">chunk-9a76d8ffa3427c606f749054f4201706&lt;SEP&gt;chunk-b26706fdda696524be1e5ff48c2836c2</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;河南&quot;">
      <data key="d4">6.0</data>
      <data key="d5">"朱重八 is sent to 河南 to beg for food, facing harsh conditions and survival challenges."</data>
      <data key="d6">chunk-b26706fdda696524be1e5ff48c2836c2</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;明教&quot;">
      <data key="d4">15.0</data>
      <data key="d5">"朱重八 joins 明教, believing in the coming of the Maitreya Buddha during dark times."&lt;SEP&gt;"朱重八信仰明教，相信弥勒佛的降世，这成为他精神力量的来源。"</data>
      <data key="d6">chunk-9a76d8ffa3427c606f749054f4201706&lt;SEP&gt;chunk-b26706fdda696524be1e5ff48c2836c2</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;父母之死&quot;">
      <data key="d4">9.0</data>
      <data key="d5">"朱重八's parents die, leaving him to struggle for survival and burial."</data>
      <data key="d6">chunk-b26706fdda696524be1e5ff48c2836c2</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;化缘&quot;">
      <data key="d4">8.0</data>
      <data key="d5">"朱重八 is forced to beg for food during a famine, facing humiliation and hardship."</data>
      <data key="d6">chunk-b26706fdda696524be1e5ff48c2836c2</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;朱重八的二哥&quot;">
      <data key="d4">8.0</data>
      <data key="d5">"Zhu Chongba and his older brother work together to bury their parents after being refused help."</data>
      <data key="d6">chunk-b26706fdda696524be1e5ff48c2836c2</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;好心人&quot;">
      <data key="d4">7.0</data>
      <data key="d5">"A kind-hearted person helps Zhu Chongba bury his parents when no one else would."</data>
      <data key="d6">chunk-b26706fdda696524be1e5ff48c2836c2</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;地主&quot;">
      <data key="d4">6.0</data>
      <data key="d5">"Zhu Chongba contrasts his family's poverty with the landlords' wealth, fueling his resentment."</data>
      <data key="d6">chunk-b26706fdda696524be1e5ff48c2836c2</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;和尚们&quot;">
      <data key="d4">7.0</data>
      <data key="d5">"The monks at 皇觉寺 exploit and mistreat Zhu Chongba during his time as a novice."</data>
      <data key="d6">chunk-b26706fdda696524be1e5ff48c2836c2</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;弥勒佛&quot;">
      <data key="d4">6.0</data>
      <data key="d5">"Zhu Chongba adopts belief in Maitreya Buddha as hope during difficult times."</data>
      <data key="d6">chunk-b26706fdda696524be1e5ff48c2836c2</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;元代&quot;">
      <data key="d4">5.0</data>
      <data key="d5">"Zhu Chongba's experiences are shaped by the social conditions of the Yuan Dynasty."</data>
      <data key="d6">chunk-b26706fdda696524be1e5ff48c2836c2</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;饥荒&quot;">
      <data key="d4">8.0</data>
      <data key="d5">"The famine forces Zhu Chongba into begging and shapes his early life struggles."</data>
      <data key="d6">chunk-b26706fdda696524be1e5ff48c2836c2</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;讨饭&quot;">
      <data key="d4">7.0</data>
      <data key="d5">"Zhu Chongba is forced to beg for food during the famine, experiencing great hardship."</data>
      <data key="d6">chunk-b26706fdda696524be1e5ff48c2836c2</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;颖州&quot;">
      <data key="d4">5.0</data>
      <data key="d5">"颖州是朱重八曾讨饭的地方，也是韩山童和刘福通起义的地点。"</data>
      <data key="d6">chunk-9a76d8ffa3427c606f749054f4201706</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;汤和&quot;">
      <data key="d4">16.0</data>
      <data key="d5">"汤和是朱重八的幼年朋友，邀请他参加起义军，影响了朱重八的命运。"&lt;SEP&gt;"汤和是朱重八的首位战友，长期并肩作战并引荐其投军。"</data>
      <data key="d6">chunk-2c6a57e1314b2c844652242279238744&lt;SEP&gt;chunk-ae09d8cc60b0994e2115ddece8322649</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;起义军&quot;">
      <data key="d4">19.0</data>
      <data key="d5">"朱重八最终加入起义军，成为推翻元朝的关键人物。"&lt;SEP&gt;"朱重八被迫加入起义军，成为其核心成员并最终领导反抗。"</data>
      <data key="d6">chunk-2c6a57e1314b2c844652242279238744&lt;SEP&gt;chunk-ae09d8cc60b0994e2115ddece8322649</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;元朝&quot;">
      <data key="d4">10.0</data>
      <data key="d5">"朱重八反抗元朝统治，最终推翻元朝并建立明朝。"</data>
      <data key="d6">chunk-2c6a57e1314b2c844652242279238744</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;师兄&quot;">
      <data key="d4">7.0</data>
      <data key="d5">"师兄告知被告发消息，直接促使朱重八参加起义。"</data>
      <data key="d6">chunk-2c6a57e1314b2c844652242279238744</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;告发事件&quot;">
      <data key="d4">8.0</data>
      <data key="d5">"告发事件是迫使朱重八参加起义的直接导火索。"</data>
      <data key="d6">chunk-2c6a57e1314b2c844652242279238744</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;周德兴&quot;">
      <data key="d4">6.0</data>
      <data key="d5">"周德兴为犹豫的朱重八提供算卦建议，促成其造反决定。"</data>
      <data key="d6">chunk-ae09d8cc60b0994e2115ddece8322649</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;郭子兴&quot;">
      <data key="d4">8.0</data>
      <data key="d5">"郭子兴赏识朱重八的才能，将其收为亲兵，开启其军事生涯。"</data>
      <data key="d6">chunk-ae09d8cc60b0994e2115ddece8322649</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;千户&quot;">
      <data key="d4">5.0</data>
      <data key="d5">"起义军千户写信邀请朱重八共谋富贵，成为其造反诱因之一。"</data>
      <data key="d6">chunk-ae09d8cc60b0994e2115ddece8322649</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;寺庙&quot;">
      <data key="d4">7.0</data>
      <data key="d5">"朱重八曾藏身寺庙躲避压迫，后因被告发而被迫造反。"</data>
      <data key="d6">chunk-ae09d8cc60b0994e2115ddece8322649</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;朱重八&quot;" target="&quot;亲兵&quot;">
      <data key="d4">8.0</data>
      <data key="d5">"朱重八因个人能力被郭子兴破格提拔为亲兵，开启军事生涯。"</data>
      <data key="d6">chunk-ae09d8cc60b0994e2115ddece8322649</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;黄河&quot;" target="&quot;元&quot;">
      <data key="d4">9.0</data>
      <data key="d5">"The flooding of the Yellow River exacerbates the Yuan Dynasty's instability, contributing to its decline."</data>
      <data key="d6">chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;元&quot;" target="&quot;淮河&quot;">
      <data key="d4">7.0</data>
      <data key="d5">"The plague and drought along the Huai River further weaken the Yuan Dynasty's control over its population."</data>
      <data key="d6">chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;脱脱&quot;" target="&quot;黄河泛滥&quot;">
      <data key="d4">8.0</data>
      <data key="d5">"脱脱's advocacy for repairing the Yellow River's levees inadvertently sets the stage for rebellion against the Yuan Dynasty."</data>
      <data key="d6">chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;脱脱&quot;" target="&quot;黄河治理&quot;">
      <data key="d4">8.0</data>
      <data key="d5">"脱脱主张治理黄河，但因官吏腐败和民怨，最终引发起义。"</data>
      <data key="d6">chunk-9a76d8ffa3427c606f749054f4201706</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;元顺帝&quot;" target="&quot;淮河沿岸瘟疫和旱灾&quot;">
      <data key="d4">6.0</data>
      <data key="d5">"元顺帝's ineffective response to the Huai River disasters reflects the corruption and inefficiency of his government."</data>
      <data key="d6">chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;元顺帝&quot;" target="&quot;尧舜禹汤&quot;">
      <data key="d4">6.0</data>
      <data key="d5">"Corrupt officials cynically compared the incompetent Yuan emperor to legendary sage rulers in their reports."</data>
      <data key="d6">chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;黄河泛滥&quot;" target="&quot;石人一只眼，挑动黄河天下反&quot;">
      <data key="d4">9.0</data>
      <data key="d5">"The Yellow River floods are linked to the prophecy of rebellion against the Yuan Dynasty."</data>
      <data key="d6">chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;黄河泛滥&quot;" target="&quot;元至正四年&quot;">
      <data key="d4">9.0</data>
      <data key="d5">"The year 1344 saw the catastrophic Yellow River floods that weakened the Yuan Dynasty."</data>
      <data key="d6">chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;淮河沿岸瘟疫和旱灾&quot;" target="&quot;元至正四年&quot;">
      <data key="d4">9.0</data>
      <data key="d5">"1344 also witnessed devastating plague and drought along the Huai River."</data>
      <data key="d6">chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;中书省&quot;" target="&quot;赈灾&quot;">
      <data key="d4">7.0</data>
      <data key="d5">"The Central Secretariat was responsible for organizing the corrupt disaster relief efforts."</data>
      <data key="d6">chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;各路&quot;" target="&quot;赈灾&quot;">
      <data key="d4">8.0</data>
      <data key="d5">"Regional administrations participated in the embezzlement of disaster relief supplies."</data>
      <data key="d6">chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;州&quot;" target="&quot;县&quot;">
      <data key="d4">7.0</data>
      <data key="d5">"The prefecture and county administrations worked together in the corrupt distribution system."</data>
      <data key="d6">chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;韩山童&quot;" target="&quot;刘福通&quot;">
      <data key="d4">17.0</data>
      <data key="d5">"韩山童和刘福通共同领导了元末农民起义，是起义的主要发起者。"&lt;SEP&gt;"韩山童和刘福通共同领导了白莲教起义，反抗元朝统治。"</data>
      <data key="d6">chunk-9a76d8ffa3427c606f749054f4201706&lt;SEP&gt;chunk-2c6a57e1314b2c844652242279238744</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;韩山童&quot;" target="&quot;白莲教&quot;">
      <data key="d4">8.0</data>
      <data key="d5">"韩山童利用白莲教组织起义，自称宋朝皇室后裔。"</data>
      <data key="d6">chunk-9a76d8ffa3427c606f749054f4201706</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;韩山童&quot;" target="&quot;宋朝&quot;">
      <data key="d4">13.0</data>
      <data key="d5">"韩山童自称宋朝皇室后裔以争取起义的合法性。"&lt;SEP&gt;"韩山童自称宋朝皇室后裔，以 legitimize 起义的正当性。"</data>
      <data key="d6">chunk-9a76d8ffa3427c606f749054f4201706&lt;SEP&gt;chunk-2c6a57e1314b2c844652242279238744</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;韩山童&quot;" target="&quot;陈胜吴广&quot;">
      <data key="d4">13.0</data>
      <data key="d5">"韩山童和刘福通的起义命运被类比为陈胜吴广的宿命。"&lt;SEP&gt;"韩山童的起义命运与陈胜吴广相似，都是农民起义的先驱者。"</data>
      <data key="d6">chunk-9a76d8ffa3427c606f749054f4201706&lt;SEP&gt;chunk-2c6a57e1314b2c844652242279238744</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;韩山童&quot;" target="&quot;元朝&quot;">
      <data key="d4">9.0</data>
      <data key="d5">"韩山童是反抗元朝统治的起义领袖，与元朝对立。"</data>
      <data key="d6">chunk-2c6a57e1314b2c844652242279238744</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;刘福通&quot;" target="&quot;白莲教&quot;">
      <data key="d4">8.0</data>
      <data key="d5">"刘福通利用白莲教组织起义，自称刘光世大将的后人。"</data>
      <data key="d6">chunk-9a76d8ffa3427c606f749054f4201706</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;刘福通&quot;" target="&quot;刘光世&quot;">
      <data key="d4">6.0</data>
      <data key="d5">"刘福通自称是刘光世大将的后人，以增强起义的号召力。"</data>
      <data key="d6">chunk-9a76d8ffa3427c606f749054f4201706</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;刘福通&quot;" target="&quot;元朝&quot;">
      <data key="d4">9.0</data>
      <data key="d5">"刘福通是反抗元朝统治的起义领袖，与元朝对立。"</data>
      <data key="d6">chunk-2c6a57e1314b2c844652242279238744</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;白莲教&quot;" target="&quot;颖州起义&quot;">
      <data key="d4">9.0</data>
      <data key="d5">"白莲教是颖州起义的组织者和领导者，利用宗教发动起义。"</data>
      <data key="d6">chunk-9a76d8ffa3427c606f749054f4201706</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;元朝&quot;" target="&quot;黄河治理&quot;">
      <data key="d4">7.0</data>
      <data key="d5">"元朝因黄河治理问题引发民怨，成为农民起义的导火索。"</data>
      <data key="d6">chunk-9a76d8ffa3427c606f749054f4201706</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;元朝&quot;" target="&quot;颖州起义&quot;">
      <data key="d4">8.0</data>
      <data key="d5">"颖州起义是反抗元朝统治的重要事件，标志着元末农民起义的开始。"</data>
      <data key="d6">chunk-9a76d8ffa3427c606f749054f4201706</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;元朝&quot;" target="&quot;至正十一年&quot;">
      <data key="d4">8.0</data>
      <data key="d5">"至正十一年是元朝走向灭亡的关键年份。"</data>
      <data key="d6">chunk-9a76d8ffa3427c606f749054f4201706</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;元朝&quot;" target="&quot;元末农民起义&quot;">
      <data key="d4">10.0</data>
      <data key="d5">"元末农民起义直接导致元朝的统治被推翻。"</data>
      <data key="d6">chunk-2c6a57e1314b2c844652242279238744</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;颖州起义&quot;" target="&quot;独眼石人&quot;">
      <data key="d4">9.0</data>
      <data key="d5">"独眼石人的发现成为颖州起义的直接导火索。"</data>
      <data key="d6">chunk-9a76d8ffa3427c606f749054f4201706</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;起义军&quot;" target="&quot;元的官吏&quot;">
      <data key="d4">8.0</data>
      <data key="d5">"元的官吏无能镇压起义军，反而滥杀百姓，加速了元朝灭亡。"</data>
      <data key="d6">chunk-2c6a57e1314b2c844652242279238744</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;起义军&quot;" target="&quot;郭子兴&quot;">
      <data key="d4">9.0</data>
      <data key="d5">"郭子兴是濠州起义军领袖，组织反抗元朝统治。"</data>
      <data key="d6">chunk-ae09d8cc60b0994e2115ddece8322649</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;蒙古人&quot;" target="&quot;南人&quot;">
      <data key="d4">9.0</data>
      <data key="d5">"蒙古人作为统治者压迫最低等级的南人，激化社会矛盾。"</data>
      <data key="d6">chunk-2c6a57e1314b2c844652242279238744</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;蒙古贵族&quot;" target="&quot;元的统治&quot;">
      <data key="d4">9.0</data>
      <data key="d5">"蒙古贵族是元朝统治的核心实施者，推行民族压迫政策。"</data>
      <data key="d6">chunk-2c6a57e1314b2c844652242279238744</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;元的统治&quot;" target="&quot;起义的熊熊烈火&quot;">
      <data key="d4">9.0</data>
      <data key="d5">"起义的爆发直接冲击和动摇了元的统治基础。"</data>
      <data key="d6">chunk-2c6a57e1314b2c844652242279238744</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;郭子兴&quot;" target="&quot;元帅府&quot;">
      <data key="d4">8.0</data>
      <data key="d5">"郭子兴在元帅府指挥濠州城防务，决定朱重八的命运。"</data>
      <data key="d6">chunk-ae09d8cc60b0994e2115ddece8322649</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;郭子兴&quot;" target="&quot;郭子兴的儿子&quot;">
      <data key="d4">7.0</data>
      <data key="d5">"郭子兴的儿子执行了父亲对朱元璋的迫害，体现了家族权力结构。"</data>
      <data key="d6">chunk-41fce71cb1f6198f0eb409c3481892ec</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;元军&quot;" target="&quot;濠州城&quot;">
      <data key="d4">7.0</data>
      <data key="d5">"元军长期围困濠州城，试图镇压起义军势力。"</data>
      <data key="d6">chunk-ae09d8cc60b0994e2115ddece8322649</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;元军&quot;" target="&quot;农民起义&quot;">
      <data key="d4">8.0</data>
      <data key="d5">"农民起义直接对抗元军，加速元朝统治的崩溃。"</data>
      <data key="d6">chunk-ae09d8cc60b0994e2115ddece8322649</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;农民起义&quot;" target="&quot;田赋和徭役&quot;">
      <data key="d4">9.0</data>
      <data key="d5">"元朝的残酷剥削直接引发农民大规模反抗。"</data>
      <data key="d6">chunk-ae09d8cc60b0994e2115ddece8322649</data>
      <data key="d7">1</data>
    </edge>
    <edge source="&quot;黄巢&quot;" target="&quot;《咏菊》&quot;">
      <data key="d4">8.0</data>
      <data key="d5">"黄巢通过《咏菊》表达反叛精神，其经历与朱元璋形成历史对照。"</data>
      <data key="d6">chunk-41fce71cb1f6198f0eb409c3481892ec</data>
      <data key="d7">1</data>
    </edge>
