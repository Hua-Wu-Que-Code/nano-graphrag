  <key id="d0" for="node" attr.name="entity_type" attr.type="string" />
  <graph edgedefault="undirected">
    <node id="&quot;朱元璋&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"朱元璋 is the later name of Zhu Chongba, who recalls the emotional pain of his parents' death and his early struggles."&lt;SEP&gt;"朱元璋是明朝的开国皇帝，曾经历被郭子兴关押的困境，后带兵出征并取得多次胜利，最终开创霸业。"&lt;SEP&gt;"朱元璋，原名朱重八，是中国明朝的开国皇帝。他出身贫农家庭，曾做过放牛娃、和尚，后参加起义并最终成为皇帝。他的童年和早期生活充满艰辛，反映了元朝末年的社会动荡和农民生活的困苦。"</data>
      <data key="d2">chunk-41fce71cb1f6198f0eb409c3481892ec&lt;SEP&gt;chunk-8091a468687529ab4647eec0e9f0e1dc&lt;SEP&gt;chunk-b26706fdda696524be1e5ff48c2836c2</data>
      <data key="d3">[{"level": 0, "cluster": 0}, {"level": 1, "cluster": 9}]</data>
    </node>
    <node id="&quot;朱五四&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"朱五四是朱元璋的父亲，一名贫农，靠种地和经营豆腐店为生。他的生活艰辛，反映了元朝时期农民的普遍困境。"</data>
      <data key="d2">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d3">[{"level": 0, "cluster": 5}]</data>
    </node>
    <node id="&quot;陈氏&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"陈氏是朱元璋的母亲，一名农民。史书中对她的记载较少，但她作为朱元璋的母亲，在朱元璋的早期生活中扮演了重要角色。"</data>
      <data key="d2">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d3">[{"level": 0, "cluster": 0}, {"level": 1, "cluster": 9}]</data>
    </node>
    <node id="&quot;刘德&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"刘德 is a landlord who refuses to help Zhu Chongba bury his parents, showing a cold and indifferent attitude."&lt;SEP&gt;"刘德 is a landlord who refuses to help朱重八 bury his parents, symbolizing the harsh realities faced by the poor."&lt;SEP&gt;"刘德是朱元璋童年时期的地主，朱元璋曾为他家放牛。刘德代表了元朝时期的地主阶级，对农民进行剥削。"</data>
      <data key="d2">chunk-b26706fdda696524be1e5ff48c2836c2&lt;SEP&gt;chunk-8091a468687529ab4647eec0e9f0e1dc&lt;SEP&gt;chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d3">[{"level": 0, "cluster": 5}]</data>
    </node>
    <node id="&quot;元王朝&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"元王朝是蒙古人建立的王朝，统治中国六十余年。其统治极其腐败，对百姓压迫严重，导致社会矛盾激化，最终被推翻。"</data>
      <data key="d2">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d3">[{"level": 0, "cluster": 5}]</data>
    </node>
    <node id="&quot;中国&quot;">
      <data key="d0">"GEO"</data>
      <data key="d1">"中国 refers to China, the country where these historical events of the Yuan Dynasty's decline are taking place."&lt;SEP&gt;"中国是朱元璋生活的国家，当时处于元王朝的统治下，社会动荡，农民生活困苦。"</data>
      <data key="d2">chunk-8091a468687529ab4647eec0e9f0e1dc&lt;SEP&gt;chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d3">[{"level": 0, "cluster": 2}]</data>
    </node>
    <node id="&quot;1344年&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"1344年是元朝末年一个关键的年份，发生了严重的自然灾害和社会动荡，为元朝的灭亡埋下了伏笔。朱元璋也在这一年经历了重大转折。"</data>
      <data key="d2">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d3">[{"level": 0, "cluster": 1}]</data>
    </node>
    <node id="&quot;朱重八&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"朱元璋的原名，意为朱八八，反映了元朝百姓取名以父母年龄或出生日期的习俗。童年为地主刘德放牛，生活贫困。"&lt;SEP&gt;"朱重八 is a young man who experiences immense personal tragedy during the Yuan Dynasty's decline, later becoming a key historical figure."&lt;SEP&gt;"朱重八, later known as Zhu Yuanzhang, is a poor peasant who struggles to survive after his parents' death, eventually becoming a monk and later a rebel leader."&lt;SEP&gt;"朱重八是明朝开国皇帝朱元璋的曾用名，他在面临告发和生存压力时被迫加入起义军，表现出冷静、勇敢和深思熟虑的特质。"&lt;SEP&gt;"朱重八（朱元璋）从一个贫苦的孩童成长为坚强的战士，经历了长期的困难生活，磨练出坚强的意志，并信仰明教，相信弥勒佛的降世。"&lt;SEP&gt;"朱重八（朱元璋）是元末农民起义领袖之一，起初犹豫是否参加起义，后因形势所迫加入，最终建立明朝。"</data>
      <data key="d2">chunk-9a76d8ffa3427c606f749054f4201706&lt;SEP&gt;chunk-2c6a57e1314b2c844652242279238744&lt;SEP&gt;chunk-ae09d8cc60b0994e2115ddece8322649&lt;SEP&gt;chunk-b26706fdda696524be1e5ff48c2836c2&lt;SEP&gt;chunk-90074c0167f1b96f110e0701bbd3370b&lt;SEP&gt;chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d3">[{"level": 0, "cluster": 3}]</data>
    </node>
    <node id="&quot;朱百六&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"朱元璋的高祖父，名字反映元朝百姓取名规则（父母年龄或日期）。"</data>
      <data key="d2">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d3">[{"level": 0, "cluster": 3}]</data>
    </node>
    <node id="&quot;朱四九&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"朱元璋的曾祖父，名字体现元朝底层民众的命名方式。"</data>
      <data key="d2">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d3">[{"level": 0, "cluster": 3}]</data>
    </node>
    <node id="&quot;朱初一&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"朱元璋的祖父，名字遵循元朝贫民数字命名传统。"</data>
      <data key="d2">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d3">[{"level": 0, "cluster": 3}]</data>
    </node>
    <node id="&quot;吴老太&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"村口的媒人，朱元璋曾幻想通过她说媒娶妻，反映其早期平凡愿望。"</data>
      <data key="d2">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d3">[{"level": 0, "cluster": 3}]</data>
    </node>
    <node id="&quot;刘小德&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"假想的地主后代，朱元璋幻想未来子女为其放牛，体现阶级固化认知。"</data>
      <data key="d2">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d3">[{"level": 0, "cluster": 3}]</data>
    </node>
    <node id="&quot;明实录&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"明代官修史书，记载朱元璋出生时"红光满地"的异象，强化君权神授叙事。"</data>
      <data key="d2">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d3">[{"level": 0, "cluster": 0}, {"level": 1, "cluster": 9}]</data>
    </node>
    <node id="&quot;元史&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"记载元朝历史的官方文献，提及蒙古统治者视百姓为累赘的暴政。"</data>
      <data key="d2">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d3">[{"level": 0, "cluster": 5}]</data>
    </node>
    <node id="&quot;黄河&quot;">
      <data key="d0">"GEO"</data>
      <data key="d1">"1344年灾变核心区域，"石人一只眼，挑动黄河天下反"预示元末起义浪潮。"&lt;SEP&gt;"黄河 is the Yellow River, which flooded in 1344, causing widespread devastation and contributing to the Yuan Dynasty's instability."</data>
      <data key="d2">chunk-8091a468687529ab4647eec0e9f0e1dc&lt;SEP&gt;chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d3">[{"level": 0, "cluster": 1}]</data>
    </node>
    <node id="&quot;破茅草屋&quot;">
      <data key="d0">"GEO"</data>
      <data key="d1">"朱元璋童年住所，描述为"冬凉夏暖、四面通风"，象征极端贫困。"</data>
      <data key="d2">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d3">[{"level": 0, "cluster": 3}]</data>
    </node>
    <node id="&quot;1328年&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"朱元璋出生年份，夜间红光异象被《明实录》神化，开启传奇人生。"</data>
      <data key="d2">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d3">[{"level": 0, "cluster": 0}, {"level": 1, "cluster": 9}]</data>
    </node>
    <node id="&quot;放牛时期&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"1328-1344年，朱元璋为地主刘德放牛的阶段，形成其早期阶级意识。"</data>
      <data key="d2">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d3">[{"level": 0, "cluster": 5}]</data>
    </node>
    <node id="&quot;做和尚时期&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"1344-1352年，朱元璋出家为僧却以讨饭为生，反映元末寺院衰败。"</data>
      <data key="d2">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d3">[{"level": 0, "cluster": 5}]</data>
    </node>
    <node id="&quot;造反时期&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"1352-1368年，朱元璋参加红巾军起义，最终推翻元朝的关键阶段。"</data>
      <data key="d2">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d3">[{"level": 0, "cluster": 5}]</data>
    </node>
    <node id="&quot;做皇帝时期&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"1368-1398年，朱元璋建立明朝并统治的三十年，开创洪武之治。"</data>
      <data key="d2">chunk-8091a468687529ab4647eec0e9f0e1dc</data>
      <data key="d3">[{"level": 0, "cluster": 0}, {"level": 1, "cluster": 9}]</data>
    </node>
    <node id="&quot;元&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"元 refers to the Yuan Dynasty, a historical empire in China that faced significant challenges including natural disasters and internal strife."</data>
      <data key="d2">chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d3">[{"level": 0, "cluster": 1}]</data>
    </node>
    <node id="&quot;淮河&quot;">
      <data key="d0">"GEO"</data>
      <data key="d1">"淮河 is the Huai River, which suffered from severe plague and drought during the same period as the Yellow River floods."</data>
      <data key="d2">chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d3">[{"level": 0, "cluster": 1}]</data>
    </node>
    <node id="&quot;山东&quot;">
      <data key="d0">"GEO"</data>
      <data key="d1">"山东 is a province in China affected by the Yellow River floods, leading to many refugees."&lt;SEP&gt;"山东是民工挖出独眼石人的地方，这一发现成为起义的导火索。"</data>
      <data key="d2">chunk-9a76d8ffa3427c606f749054f4201706&lt;SEP&gt;chunk-90074c0167f1b96f110e0701bbd3370b</data>
    </node>
    <node id="&quot;河南&quot;">
      <data key="d0">"GEO"</data>
      <data key="d1">"河南 is another province in China affected by the Yellow River floods, exacerbating the humanitarian crisis."&lt;SEP&gt;"河南 is another region where Zhu Chongba is sent to beg for food, facing harsh conditions and survival challenges."</data>
      <data key="d2">chunk-b26706fdda696524be1e5ff48c2836c2&lt;SEP&gt;chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d3">[{"level": 0, "cluster": 3}]</data>
    </node>
    <node id="&quot;脱脱&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"脱脱 is a famous chancellor of the Yuan Dynasty who advocated for repairing the Yellow River's levees, unknowingly contributing to the dynasty's downfall."&lt;SEP&gt;"脱脱是元朝官员，主张治理黄河，但因不了解官吏腐败和反对者的苦心，最终导致民怨和起义。"</data>
      <data key="d2">chunk-9a76d8ffa3427c606f749054f4201706&lt;SEP&gt;chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d3">[{"level": 0, "cluster": 7}]</data>
    </node>
    <node id="&quot;元顺帝&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"元顺帝 is the emperor of the Yuan Dynasty during this period, whose government was marked by corruption and inefficiency."</data>
      <data key="d2">chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d3">[{"level": 0, "cluster": 7}]</data>
    </node>
    <node id="&quot;黄河泛滥&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"黄河泛滥 refers to the flooding of the Yellow River in 1344, a disaster that displaced thousands and strained the Yuan Dynasty's resources."</data>
      <data key="d2">chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d3">[{"level": 0, "cluster": 7}]</data>
    </node>
    <node id="&quot;淮河沿岸瘟疫和旱灾&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"淮河沿岸瘟疫和旱灾 describes the plague and drought along the Huai River, compounding the suffering of the population."</data>
      <data key="d2">chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d3">[{"level": 0, "cluster": 7}]</data>
    </node>
    <node id="&quot;石人一只眼，挑动黄河天下反&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"石人一只眼，挑动黄河天下反 is a prophetic statement indicating the coming rebellion against the Yuan Dynasty, linked to the Yellow River floods."</data>
      <data key="d2">chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d3">[{"level": 0, "cluster": 7}]</data>
    </node>
    <node id="&quot;元代&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"The Yuan Dynasty period during which these events take place, influencing social structures like monk marriages."&lt;SEP&gt;"元代 refers to the administrative system of the Yuan Dynasty, characterized by corruption and inefficiency during this period."</data>
      <data key="d2">chunk-b26706fdda696524be1e5ff48c2836c2&lt;SEP&gt;chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d3">[{"level": 0, "cluster": 2}]</data>
    </node>
    <node id="&quot;中书省&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"中书省 is the Central Secretariat of the Yuan Dynasty government, responsible for handling disasters but plagued by corruption."</data>
      <data key="d2">chunk-90074c0167f1b96f110e0701bbd3370b</data>
    </node>
    <node id="&quot;各路&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"各路 refers to the regional administrative units of the Yuan Dynasty where relief supplies were systematically embezzled."</data>
      <data key="d2">chunk-90074c0167f1b96f110e0701bbd3370b</data>
    </node>
    <node id="&quot;州&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"州 represents the prefecture-level administrative units in Yuan Dynasty's hierarchy that participated in the corruption chain."</data>
      <data key="d2">chunk-90074c0167f1b96f110e0701bbd3370b</data>
    </node>
    <node id="&quot;县&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"县 refers to county-level administrations that were the final link in the corrupt distribution of disaster relief."</data>
      <data key="d2">chunk-90074c0167f1b96f110e0701bbd3370b</data>
    </node>
    <node id="&quot;尧舜禹汤&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"尧舜禹汤 are legendary sage emperors of Chinese antiquity, cynically compared to the Yuan emperor in corrupt officials' reports."</data>
      <data key="d2">chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d3">[{"level": 0, "cluster": 7}]</data>
    </node>
    <node id="&quot;朱重八的父亲&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"朱重八的父亲 was a poor peasant who worked as a tenant farmer and died of starvation during the disasters."</data>
      <data key="d2">chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d3">[{"level": 0, "cluster": 3}]</data>
    </node>
    <node id="&quot;朱重八的大哥&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"朱重八的大哥 was another victim of the famine, dying shortly after their father."</data>
      <data key="d2">chunk-90074c0167f1b96f110e0701bbd3370b</data>
    </node>
    <node id="&quot;朱重八的母亲&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"朱重八的母亲 was a kind parent who died of starvation, leaving young朱重八 orphaned."</data>
      <data key="d2">chunk-90074c0167f1b96f110e0701bbd3370b</data>
    </node>
    <node id="&quot;朱重八的大哥长子&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"朱重八的大哥长子 was the nephew who also perished in the famine, showing the family's complete devastation."</data>
      <data key="d2">chunk-90074c0167f1b96f110e0701bbd3370b</data>
    </node>
    <node id="&quot;朱重八的二哥&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"朱重八's older brother who helps him carry their parents' bodies for burial."&lt;SEP&gt;"朱重八的二哥 was the only surviving family member who helped朱重八 bury their parents."</data>
      <data key="d2">chunk-b26706fdda696524be1e5ff48c2836c2&lt;SEP&gt;chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d3">[{"level": 0, "cluster": 3}]</data>
    </node>
    <node id="&quot;朱重八的姐姐&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"朱重八的姐姐 had married out of the family before the disasters struck."</data>
      <data key="d2">chunk-90074c0167f1b96f110e0701bbd3370b</data>
    </node>
    <node id="&quot;朱重八的三哥&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"朱重八的三哥 had left to become a live-in son-in-law elsewhere before the famine."</data>
      <data key="d2">chunk-90074c0167f1b96f110e0701bbd3370b</data>
    </node>
    <node id="&quot;地主家&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"地主家 represents the landlord class that controlled resources and showed no mercy to starving peasants like朱重八's family."</data>
      <data key="d2">chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d3">[{"level": 0, "cluster": 3}]</data>
    </node>
    <node id="&quot;元至正四年&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"元至正四年 (1344 AD) marks the year of catastrophic disasters that accelerated the Yuan Dynasty's collapse."</data>
      <data key="d2">chunk-90074c0167f1b96f110e0701bbd3370b</data>
      <data key="d3">[{"level": 0, "cluster": 7}]</data>
    </node>
    <node id="&quot;赈灾&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"赈灾 refers to the corrupt disaster relief efforts that failed to help actual victims like朱重八's family."</data>
      <data key="d2">chunk-90074c0167f1b96f110e0701bbd3370b</data>
    </node>
    <node id="&quot;皇觉寺&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"皇觉寺 is a temple where Zhu Chongba becomes a monk, but he is treated poorly and forced to do menial tasks."&lt;SEP&gt;"皇觉寺是朱重八曾生活和修行的地方，也是他漂泊后回归的地方。"</data>
      <data key="d2">chunk-9a76d8ffa3427c606f749054f4201706&lt;SEP&gt;chunk-b26706fdda696524be1e5ff48c2836c2</data>
      <data key="d3">[{"level": 0, "cluster": 3}]</data>
    </node>
    <node id="&quot;淮西&quot;">
      <data key="d0">"GEO"</data>
      <data key="d1">"淮西 is a region where Zhu Chongba is sent to beg for food during a famine, and where he gains valuable experience and connections."&lt;SEP&gt;"淮西是朱重八讨饭的地方，他在这里度过了三年时光，经历了人生的重大转变。"</data>
      <data key="d2">chunk-9a76d8ffa3427c606f749054f4201706&lt;SEP&gt;chunk-b26706fdda696524be1e5ff48c2836c2</data>
      <data key="d3">[{"level": 0, "cluster": 3}]</data>
    </node>
    <node id="&quot;明教&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"明教 is a religious group that Zhu Chongba joins, believing in the coming of the Maitreya Buddha during dark times."&lt;SEP&gt;"明教是一个宗教信仰组织，朱重八信仰明教，相信弥勒佛会在黑暗时代降世。"</data>
      <data key="d2">chunk-9a76d8ffa3427c606f749054f4201706&lt;SEP&gt;chunk-b26706fdda696524be1e5ff48c2836c2</data>
      <data key="d3">[{"level": 0, "cluster": 3}]</data>
    </node>
    <node id="&quot;父母之死&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"父母之死 is the event where Zhu Chongba's parents die, leaving him to struggle for survival and burial."</data>
      <data key="d2">chunk-b26706fdda696524be1e5ff48c2836c2</data>
      <data key="d3">[{"level": 0, "cluster": 3}]</data>
    </node>
    <node id="&quot;化缘&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"化缘 is the event where Zhu Chongba is forced to beg for food during a famine, facing humiliation and hardship."</data>
      <data key="d2">chunk-b26706fdda696524be1e5ff48c2836c2</data>
      <data key="d3">[{"level": 0, "cluster": 3}]</data>
    </node>
    <node id="&quot;好心人&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"A kind-hearted person who gives Zhu Chongba and his brother land to bury their parents."</data>
      <data key="d2">chunk-b26706fdda696524be1e5ff48c2836c2</data>
      <data key="d3">[{"level": 0, "cluster": 3}]</data>
    </node>
    <node id="&quot;地主&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Landlords who own the land but don't work it, contrasting with peasants like Zhu Chongba's family."</data>
      <data key="d2">chunk-b26706fdda696524be1e5ff48c2836c2</data>
      <data key="d3">[{"level": 0, "cluster": 3}]</data>
    </node>
    <node id="&quot;和尚们&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"The monks at 皇觉寺 who treat Zhu Chongba poorly and make him do menial tasks."</data>
      <data key="d2">chunk-b26706fdda696524be1e5ff48c2836c2</data>
      <data key="d3">[{"level": 0, "cluster": 3}]</data>
    </node>
    <node id="&quot;唐僧&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"A reference to the fictional monk from Journey to the West, used to explain the concept of begging for food (化缘)."</data>
      <data key="d2">chunk-b26706fdda696524be1e5ff48c2836c2</data>
    </node>
    <node id="&quot;悟空&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"A reference to Sun Wukong from Journey to the West, mentioned in the context of begging for food."</data>
      <data key="d2">chunk-b26706fdda696524be1e5ff48c2836c2</data>
    </node>
    <node id="&quot;弥勒佛&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"The Maitreya Buddha, whom Zhu Chongba believes will come during dark times."&lt;SEP&gt;"弥勒佛是朱重八信仰的神明，被认为是黑暗时代降世的救世主。"</data>
      <data key="d2">chunk-9a76d8ffa3427c606f749054f4201706&lt;SEP&gt;chunk-b26706fdda696524be1e5ff48c2836c2</data>
      <data key="d3">[{"level": 0, "cluster": 3}]</data>
    </node>
    <node id="&quot;太上老君&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"A Taoist deity whom Zhu Chongba prays to during his desperate times."</data>
      <data key="d2">chunk-b26706fdda696524be1e5ff48c2836c2</data>
    </node>
    <node id="&quot;如来佛祖&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"The Buddha whom Zhu Chongba prays to during his desperate times."</data>
      <data key="d2">chunk-b26706fdda696524be1e5ff48c2836c2</data>
    </node>
    <node id="&quot;饥荒&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"The severe famine that forces Zhu Chongba and other monks to beg for food."</data>
      <data key="d2">chunk-b26706fdda696524be1e5ff48c2836c2</data>
      <data key="d3">[{"level": 0, "cluster": 3}]</data>
    </node>
    <node id="&quot;讨饭&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"The act of begging for food that Zhu Chongba is forced into during the famine."</data>
      <data key="d2">chunk-b26706fdda696524be1e5ff48c2836c2</data>
      <data key="d3">[{"level": 0, "cluster": 3}]</data>
    </node>
    <node id="&quot;颖州&quot;">
      <data key="d0">"GEO"</data>
      <data key="d1">"颖州（今安徽阜阳）是韩山童和刘福通起义的地方，也是朱重八曾讨饭的地方。"</data>
      <data key="d2">chunk-9a76d8ffa3427c606f749054f4201706</data>
      <data key="d3">[{"level": 0, "cluster": 3}]</data>
    </node>
    <node id="&quot;韩山童&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"韩山童是元末农民起义领袖，自称宋朝皇室后裔，第一个举起反抗元朝统治的大旗，最终起义被镇压。"&lt;SEP&gt;"韩山童是白莲教起义的领袖，自称宋朝皇室后裔，与刘福通一起发动起义。"</data>
      <data key="d2">chunk-9a76d8ffa3427c606f749054f4201706&lt;SEP&gt;chunk-2c6a57e1314b2c844652242279238744</data>
      <data key="d3">[{"level": 0, "cluster": 4}, {"level": 1, "cluster": 12}]</data>
    </node>
    <node id="&quot;刘福通&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"刘福通是元末农民起义领袖，自称刘光世大将后人，与韩山童共同起义反抗元朝统治。"&lt;SEP&gt;"刘福通是白莲教起义的领袖，自称刘光世大将的后人，与韩山童一起发动起义。"</data>
      <data key="d2">chunk-9a76d8ffa3427c606f749054f4201706&lt;SEP&gt;chunk-2c6a57e1314b2c844652242279238744</data>
      <data key="d3">[{"level": 0, "cluster": 4}, {"level": 1, "cluster": 12}]</data>
    </node>
    <node id="&quot;白莲教&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"白莲教是一个宗教组织，韩山童和刘福通利用其发动起义，反抗元朝统治。"</data>
      <data key="d2">chunk-9a76d8ffa3427c606f749054f4201706</data>
      <data key="d3">[{"level": 0, "cluster": 4}, {"level": 1, "cluster": 13}]</data>
    </node>
    <node id="&quot;元朝&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"元朝是当时的统治王朝，腐败严重，最终因黄河治理问题和农民起义走向灭亡。"&lt;SEP&gt;"元朝是蒙古人建立的封建王朝，实行四等人制度，压迫汉人，最终被农民起义推翻。"</data>
      <data key="d2">chunk-9a76d8ffa3427c606f749054f4201706&lt;SEP&gt;chunk-2c6a57e1314b2c844652242279238744</data>
      <data key="d3">[{"level": 0, "cluster": 4}, {"level": 1, "cluster": 11}]</data>
    </node>
    <node id="&quot;黄河治理&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"黄河治理是元朝末年的一项重要工程，因官吏腐败和克扣工钱引发民怨，成为起义的导火索。"</data>
      <data key="d2">chunk-9a76d8ffa3427c606f749054f4201706</data>
      <data key="d3">[{"level": 0, "cluster": 7}]</data>
    </node>
    <node id="&quot;颖州起义&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"颖州起义是韩山童和刘福通领导的白莲教起义，反抗元朝统治，标志着元末农民起义的开始。"</data>
      <data key="d2">chunk-9a76d8ffa3427c606f749054f4201706</data>
      <data key="d3">[{"level": 0, "cluster": 4}, {"level": 1, "cluster": 13}]</data>
    </node>
    <node id="&quot;独眼石人&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"民工在山东挖出独眼石人，背部刻有‘石人一只眼，挑动黄河天下反’的谶语，成为起义的象征。"</data>
      <data key="d2">chunk-9a76d8ffa3427c606f749054f4201706</data>
      <data key="d3">[{"level": 0, "cluster": 4}, {"level": 1, "cluster": 13}]</data>
    </node>
    <node id="&quot;宋朝&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"宋朝是中国历史上的一个朝代，韩山童自称是其皇室后裔以争取支持。"&lt;SEP&gt;"韩山童自称宋朝皇室后裔，以此 legitimize 起义的正当性。"</data>
      <data key="d2">chunk-9a76d8ffa3427c606f749054f4201706&lt;SEP&gt;chunk-2c6a57e1314b2c844652242279238744</data>
      <data key="d3">[{"level": 0, "cluster": 4}, {"level": 1, "cluster": 12}]</data>
    </node>
    <node id="&quot;刘光世&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"刘福通自称是刘光世大将的后人，以此增强起义的号召力。"</data>
      <data key="d2">chunk-9a76d8ffa3427c606f749054f4201706</data>
      <data key="d3">[{"level": 0, "cluster": 4}, {"level": 1, "cluster": 12}]</data>
    </node>
    <node id="&quot;陈胜吴广&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"陈胜吴广是历史上早期农民起义的领袖，文中用来类比韩山童和刘福通的命运。"&lt;SEP&gt;"陈胜吴广是秦末农民起义领袖，文中被作为农民起义宿命的象征性人物。"</data>
      <data key="d2">chunk-9a76d8ffa3427c606f749054f4201706&lt;SEP&gt;chunk-2c6a57e1314b2c844652242279238744</data>
      <data key="d3">[{"level": 0, "cluster": 4}, {"level": 1, "cluster": 12}]</data>
    </node>
    <node id="&quot;至正十一年&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"至正十一年（1351年）是元朝末年关键的一年，黄河治理和农民起义爆发。"</data>
      <data key="d2">chunk-9a76d8ffa3427c606f749054f4201706</data>
      <data key="d3">[{"level": 0, "cluster": 4}, {"level": 1, "cluster": 11}]</data>
    </node>
    <node id="&quot;汤和&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"汤和是朱元璋的部下，后来成为明王朝的高级干部。"&lt;SEP&gt;"汤和是朱重八的幼年朋友，起义军千户，写信邀请朱重八参加起义军。"&lt;SEP&gt;"汤和是朱重八的第一个战友，长期陪伴他参与起义，并在军中为其提供支持。"</data>
      <data key="d2">chunk-2c6a57e1314b2c844652242279238744&lt;SEP&gt;chunk-41fce71cb1f6198f0eb409c3481892ec&lt;SEP&gt;chunk-ae09d8cc60b0994e2115ddece8322649</data>
      <data key="d3">[{"level": 0, "cluster": 3}]</data>
    </node>
    <node id="&quot;起义军&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"起义军是元末反抗元朝统治的农民武装力量，由韩山童、刘福通、朱重八等领导。"&lt;SEP&gt;"起义军是反抗元朝统治的农民武装力量，朱重八、汤和等人均加入其中。"</data>
      <data key="d2">chunk-2c6a57e1314b2c844652242279238744&lt;SEP&gt;chunk-ae09d8cc60b0994e2115ddece8322649</data>
      <data key="d3">[{"level": 0, "cluster": 6}]</data>
    </node>
    <node id="&quot;元末农民起义&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"元末农民起义是1351年爆发的反抗元朝统治的大规模起义，由韩山童、刘福通等领导，最终导致元朝灭亡。"</data>
      <data key="d2">chunk-2c6a57e1314b2c844652242279238744</data>
      <data key="d3">[{"level": 0, "cluster": 4}, {"level": 1, "cluster": 11}]</data>
    </node>
    <node id="&quot;蒙古人&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"蒙古人是元朝统治阶层，享有最高等级特权，压迫其他民族。"</data>
      <data key="d2">chunk-2c6a57e1314b2c844652242279238744</data>
    </node>
    <node id="&quot;南人&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"南人是元朝四等人制度中最低等级，遭受严重压迫和歧视。"</data>
      <data key="d2">chunk-2c6a57e1314b2c844652242279238744</data>
    </node>
    <node id="&quot;元的官吏&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"元的官吏在镇压起义中腐败无能，甚至滥杀百姓充数，加速了元朝灭亡。"</data>
      <data key="d2">chunk-2c6a57e1314b2c844652242279238744</data>
      <data key="d3">[{"level": 0, "cluster": 6}]</data>
    </node>
    <node id="&quot;师兄&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"朱重八的师兄告知他被告发的消息，迫使他最终决定参加起义。"</data>
      <data key="d2">chunk-2c6a57e1314b2c844652242279238744</data>
      <data key="d3">[{"level": 0, "cluster": 3}]</data>
    </node>
    <node id="&quot;宋朝皇室&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"韩山童自称宋朝皇室后裔以获取起义合法性。"</data>
      <data key="d2">chunk-2c6a57e1314b2c844652242279238744</data>
    </node>
    <node id="&quot;刘光世大将&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"刘福通自称是刘光世大将的后人，以此获取起义的正当性。"</data>
      <data key="d2">chunk-2c6a57e1314b2c844652242279238744</data>
    </node>
    <node id="&quot;蒙古贵族&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"蒙古贵族是元朝统治核心，掠夺压迫百姓，激化社会矛盾。"</data>
      <data key="d2">chunk-2c6a57e1314b2c844652242279238744</data>
    </node>
    <node id="&quot;元的统治&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"元的统治指元朝对中国的封建统治，以民族压迫和阶级剥削为特征。"</data>
      <data key="d2">chunk-2c6a57e1314b2c844652242279238744</data>
    </node>
    <node id="&quot;起义的熊熊烈火&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"象征元末农民起义的广泛爆发和不可阻挡之势。"</data>
      <data key="d2">chunk-2c6a57e1314b2c844652242279238744</data>
    </node>
    <node id="&quot;告发事件&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"朱重八被告发看义军信件的事件，迫使他最终决定参加起义。"</data>
      <data key="d2">chunk-2c6a57e1314b2c844652242279238744</data>
      <data key="d3">[{"level": 0, "cluster": 3}]</data>
    </node>
    <node id="&quot;周德兴&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"周德兴是朱元璋的部下，曾为他算命，后来成为明王朝的高级干部。"&lt;SEP&gt;"周德兴是朱重八的友人，为他提供算卦建议，间接促使朱重八决定造反。"</data>
      <data key="d2">chunk-ae09d8cc60b0994e2115ddece8322649&lt;SEP&gt;chunk-41fce71cb1f6198f0eb409c3481892ec</data>
      <data key="d3">[{"level": 0, "cluster": 0}, {"level": 1, "cluster": 9}]</data>
    </node>
    <node id="&quot;郭子兴&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"郭子兴是朱元璋的岳父和统帅，性情暴躁，曾试图饿死朱元璋，后被朱元璋决裂。"&lt;SEP&gt;"郭子兴是濠州起义军领袖，因朱重八的镇定和才能将其收为亲兵，成为其早期伯乐。"</data>
      <data key="d2">chunk-ae09d8cc60b0994e2115ddece8322649&lt;SEP&gt;chunk-41fce71cb1f6198f0eb409c3481892ec</data>
      <data key="d3">[{"level": 0, "cluster": 6}]</data>
    </node>
    <node id="&quot;元军&quot;">
      <data key="d0">"ORGANIZATION"</data>
      <data key="d1">"元军是元朝政府军队，围困濠州城并镇压起义军。"&lt;SEP&gt;"元军是朱元璋在定远等地作战的敌方军队。"</data>
      <data key="d2">chunk-ae09d8cc60b0994e2115ddece8322649&lt;SEP&gt;chunk-41fce71cb1f6198f0eb409c3481892ec</data>
      <data key="d3">[{"level": 0, "cluster": 8}]</data>
    </node>
    <node id="&quot;濠州城&quot;">
      <data key="d0">"GEO"</data>
      <data key="d1">"濠州城是起义军据点之一，被元军围困，朱重八在此投奔郭子兴。"</data>
      <data key="d2">chunk-ae09d8cc60b0994e2115ddece8322649</data>
